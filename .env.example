# =============================================================================
# NKDash Solo Mode — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
# =============================================================================

# --- Data Lake Path (bind mount) ---
# Default: ./data-lake (relative to docker-compose.yml)
# DATA_LAKE_PATH=./data-lake

# --- Dashboard Ports ---
# NKDASH_PORT=8050
# NKDASH_ADMIN_PORT=8501

# --- Dashboard Cache ---
# DASH_CACHE_TTL_SECONDS=600

# --- Odoo Connection (for ETL scheduler) ---
ODOO_HOST=your-odoo-instance.com
ODOO_PORT=443
ODOO_PROTOCOL=jsonrpc+ssl
ODOO_DB=your_db_name
ODOO_USERNAME=your_api_user
ODOO_API_KEY=your_api_key
